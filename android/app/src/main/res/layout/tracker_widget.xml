<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Tracker"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textColor="#55FFFFFF"
            android:textSize="10sp" />
    </RelativeLayout>

    <!-- ── TASKS label ──────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:text="TASKS"
        android:textColor="#818CF8"
        android:textSize="9sp"
        android:textStyle="bold" />

    <!-- Task row 1 -->
    <LinearLayout
        android:id="@+id/task_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/task_dot_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="●"
            android:textColor="#818CF8"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/task_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/task_due_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Task row 2 -->
    <LinearLayout
        android:id="@+id/task_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/task_dot_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="●"
            android:textColor="#818CF8"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/task_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/task_due_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Task row 3 -->
    <LinearLayout
        android:id="@+id/task_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/task_dot_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="●"
            android:textColor="#818CF8"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/task_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/task_due_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Task row 4 -->
    <LinearLayout
        android:id="@+id/task_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/task_dot_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="●"
            android:textColor="#818CF8"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/task_title_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/task_due_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#888888"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Shown when there are no active tasks -->
    <TextView
        android:id="@+id/no_tasks_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="All caught up! 🎉"
        android:textColor="#55FFFFFF"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- ── Divider ────────────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="7dp"
        android:layout_marginTop="3dp"
        android:background="#1A2740" />

    <!-- ── HABITS label ──────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:text="HABITS"
        android:textColor="#34D399"
        android:textSize="9sp"
        android:textStyle="bold" />

    <!-- Habit row 1 -->
    <LinearLayout
        android:id="@+id/habit_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/habit_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/habit_streak_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Habit row 2 -->
    <LinearLayout
        android:id="@+id/habit_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/habit_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/habit_streak_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Habit row 3 -->
    <LinearLayout
        android:id="@+id/habit_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/habit_name_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/habit_streak_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
