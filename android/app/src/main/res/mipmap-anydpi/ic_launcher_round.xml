<?xml version="1.0" encoding="utf-8"?>
<!-- Fallback round launcher icon for API < 26 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#4F46E5"/>
        </shape>
    </item>
    <item android:gravity="center" android:bottom="26dp" android:left="20dp" android:right="20dp" android:top="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <stroke android:width="5dp" android:color="#FFFFFF"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</layer-list>
