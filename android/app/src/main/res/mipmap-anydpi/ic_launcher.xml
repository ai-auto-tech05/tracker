<?xml version="1.0" encoding="utf-8"?>
<!-- Fallback launcher icon for API < 26 (no adaptive icons) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/ic_launcher_background"/>
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#33FFFFFF"/>
            <size android:width="72dp" android:height="72dp"/>
        </shape>
    </item>
    <item android:gravity="center" android:bottom="22dp" android:left="18dp" android:right="18dp" android:top="22dp">
        <rotate android:fromDegrees="0">
            <shape android:shape="rectangle">
                <solid android:color="#00000000"/>
                <stroke android:width="5dp" android:color="#FFFFFF"/>
                <corners android:radius="4dp"/>
            </shape>
        </rotate>
    </item>
</layer-list>
